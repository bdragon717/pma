{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk" // 테스트용 .apk 파일이 생성
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true, // 빌드 번호(Version Code)가 자동증가
      "android": {
        "buildType": "apk" // 최종 배포용 .apk 파일이 생성, "app-bundle" - 구글 플레이 스토어
      }
    }
  },
  "submit": {
    "production": {}
  }
}
